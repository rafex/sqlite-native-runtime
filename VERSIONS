# VERSIONS — Versiones de los artefactos publicados en GitHub Packages (GHCR).
#
# Flujo de uso:
#   1. Edita este archivo (versiones + AUTO_RELEASE)
#   2. Haz push del tag:   just tag-push
#      → publish.yml compila todo y publica en GHCR.
#      → Si AUTO_RELEASE=true, dispara release.yml automáticamente al terminar.
#      → Si AUTO_RELEASE=false, lanza el release cuando quieras: just release <tag>
#
# RUST        = tag del que provienen las librerías Rust (.so) en GHCR.
#               Puede ser un tag v* (publicado por publish.yml) o
#               un tag independiente (publicado por build-rust.yml manual).
#
# JAVA_FAT    = tag del que provienen los JARs thin+fat en GHCR.
#               Normalmente coincide con el tag del release Java.
#
# JAVA_NATIVE = tag del que provienen los binarios GraalVM native en GHCR.
#               Normalmente coincide con JAVA_FAT.
#
# AUTO_RELEASE = true  → publish.yml dispara release.yml automáticamente al terminar.
#                false → el release se lanza manualmente con: just release <tag>
#
# Formato: KEY=valor  (sin espacios ni comillas)

RUST=v0.4.0
JAVA_FAT=v0.4.0
JAVA_NATIVE=v0.4.0
AUTO_RELEASE=true
