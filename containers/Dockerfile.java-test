# ─────────────────────────────────────────────────────────────────────────────
# TT-3 + TT-3i — Java unit tests + integration tests
#
# Build multi-stage:
#   1. rust-builder   → compila libether_sqlite_runtime.so (Linux amd64/arm64)
#   2. java25-tester  → mvn test (Java 25, Panama FFM estable, JEP 454)
#   3. java21-tester  → mvn test (Java 21, Panama FFM preview, JEP 442)
#
# Uso local  : make container-test-java           (Podman)
# CI         : make container-test-java CONTAINER_ENGINE=docker
# Manual     : podman build -f containers/Dockerfile.java-test -t snr-java-test .
#              podman run --rm snr-java-test
# ─────────────────────────────────────────────────────────────────────────────

# ── Etapa 1: Compilar la librería nativa Rust ─────────────────────────────────

FROM debian:12-slim AS rust-builder

ARG RUST_VERSION=stable

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      curl \
      ca-certificates \
      build-essential \
 && rm -rf /var/lib/apt/lists/*

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --profile minimal --default-toolchain ${RUST_VERSION}

ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app/rust

# Caching de dependencias: manifiestos antes que código fuente
COPY sqlite-native-runtime/rust/ether-sqlite/Cargo.toml ./Cargo.toml
COPY sqlite-native-runtime/rust/ether-sqlite/Cargo.lock* ./

RUN mkdir -p src \
 && printf 'pub fn _placeholder() {}' > src/lib.rs \
 && cargo build --release 2>&1 | tail -5 \
 && rm -rf src target

COPY sqlite-native-runtime/rust/ether-sqlite/src ./src
COPY sqlite-native-runtime/rust/ether-sqlite/tests ./tests

# Compilar la .so release (el artifact que usa Java)
RUN cargo build --release \
 && ls -lh target/release/libether_sqlite_runtime.so

# ── Etapa 2: Tests Java 25 (Panama FFM estable, sin --enable-preview) ─────────
#
# ghcr.io/graalvm/jdk-community:25 incluye JDK 25 completo.
# eclipse-temurin no publica imagen :25 aún; GraalVM Community es el JDK 25
# más estable disponible como imagen Docker.

FROM ghcr.io/graalvm/jdk-community:25 AS java25-tester

WORKDIR /app/java25

# Caching de dependencias Maven: manifiestos antes que código
COPY sqlite-native-runtime/java/ether-sqlite/.mvn   ./.mvn
COPY sqlite-native-runtime/java/ether-sqlite/mvnw   ./
COPY sqlite-native-runtime/java/ether-sqlite/pom.xml ./
RUN chmod +x mvnw \
 && ./mvnw dependency:go-offline --no-transfer-progress -q

COPY sqlite-native-runtime/java/ether-sqlite/src ./src

COPY --from=rust-builder \
     /app/rust/target/release/libether_sqlite_runtime.so \
     /usr/local/lib/libether_sqlite_runtime.so

ENV ETHER_SQLITE_LIB=/usr/local/lib/libether_sqlite_runtime.so

# TT-3 : unit tests
# TT-3i: integration tests @Tag("integration")
# JaCoCo se omite aquí: el Docker CI verifica que los tests pasan,
# no genera reportes de cobertura (se ejecutan en CI dedicado con mvn verify).
RUN ./mvnw test -Djacoco.skip=true --no-transfer-progress \
 && ./mvnw test -Pintegration -Djacoco.skip=true --no-transfer-progress

# ── Etapa 3: Tests Java 21 (Panama FFM preview, --enable-preview) ─────────────
#
# El bytecode Java 21 preview (minor_version=0xFFFF) SOLO puede ejecutarse
# en una JVM Java 21 con --enable-preview. Se usa eclipse-temurin:21-jdk.

FROM eclipse-temurin:21-jdk-noble AS java21-tester

WORKDIR /app/java21

# Caching de dependencias Maven: manifiestos antes que código
COPY sqlite-native-runtime/java/ether-sqlite-java21/.mvn   ./.mvn
COPY sqlite-native-runtime/java/ether-sqlite-java21/mvnw   ./
COPY sqlite-native-runtime/java/ether-sqlite-java21/pom.xml ./
RUN chmod +x mvnw \
 && ./mvnw dependency:go-offline --no-transfer-progress -q

COPY sqlite-native-runtime/java/ether-sqlite-java21/src ./src

COPY --from=rust-builder \
     /app/rust/target/release/libether_sqlite_runtime.so \
     /usr/local/lib/libether_sqlite_runtime.so

ENV ETHER_SQLITE_LIB=/usr/local/lib/libether_sqlite_runtime.so

# enable-preview ya configurado en pom.xml de ether-sqlite-java21
RUN ./mvnw test -Djacoco.skip=true --no-transfer-progress \
 && ./mvnw test -Pintegration -Djacoco.skip=true --no-transfer-progress

# ── Etapa final: arrastra ambas etapas de test ────────────────────────────────

FROM debian:12-slim AS java-tester

COPY --from=java25-tester /app/java25/target/surefire-reports/ /reports/java25/
COPY --from=java21-tester /app/java21/target/surefire-reports/ /reports/java21/

CMD ["echo", "Java 25 + Java 21 tests OK"]
