# ─────────────────────────────────────────────────────────────────────────────
# TT-1 + TT-2 — Rust unit tests + FFI contract tests + compilación del workspace
#
# Uso local  : make container-test-rust           (Podman)
# CI         : make container-test-rust CONTAINER_ENGINE=docker
# Manual     : podman build -f containers/Dockerfile.rust-test -t snr-rust-test .
#              podman run --rm snr-rust-test
#
# Base       : debian:12-slim (Debian Bookworm)
# Build ctx  : raiz del repositorio (el script pasa $ROOT como contexto)
# SQLite     : bundled en libsqlite3-sys (no requiere libsqlite3-dev del sistema)
#
# Estructura del workspace Rust (sources/rust/):
#   Cargo.toml          <- workspace
#   ether-sqlite-core/  <- rlib, 137 unit tests + tests/ffi_contract.rs
#   ether-sqlite-ffm/   <- cdylib, re-exporta core (sin tests propios, se compila)
#   ether-sqlite-jni/   <- cdylib, ABI JNI (sin tests propios, se compila)
#
# Pasos de validación:
#   TT-1: cargo test -p ether-sqlite-core --lib       (137 unit tests internos)
#   TT-2: cargo test -p ether-sqlite-core --test      (FFI contract tests)
#   TT-3: cargo build -p ether-sqlite-ffm              (compila el cdylib FFM)
#   TT-4: cargo build -p ether-sqlite-jni              (compila el cdylib JNI)
# ─────────────────────────────────────────────────────────────────────────────

FROM debian:12-slim

ARG RUST_VERSION=stable

# build-essential: gcc + make (necesarios para compilar SQLite bundled via cc crate)
# curl + ca-certificates: para descargar rustup
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      curl \
      ca-certificates \
      build-essential \
 && rm -rf /var/lib/apt/lists/*

# Instalar Rust (perfil minimal: rustc + cargo, sin docs ni clippy)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --profile minimal --default-toolchain ${RUST_VERSION} \
 && /root/.cargo/bin/rustup show

ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

# ── Caching de dependencias con cargo fetch ────────────────────────────────
# cargo fetch descarga todas las dependencias del workspace usando solo los
# Cargo.toml + Cargo.lock, sin necesitar el código fuente real.
# Si solo cambia src/ pero no los manifiestos, esta capa se reutiliza.
COPY sources/rust/Cargo.toml             ./Cargo.toml
COPY sources/rust/Cargo.lock             ./Cargo.lock
COPY sources/rust/ether-sqlite-core/Cargo.toml ./ether-sqlite-core/Cargo.toml
COPY sources/rust/ether-sqlite-ffm/Cargo.toml  ./ether-sqlite-ffm/Cargo.toml
COPY sources/rust/ether-sqlite-jni/Cargo.toml  ./ether-sqlite-jni/Cargo.toml

# cargo fetch valida que src/lib.rs exista para cada miembro del workspace
# aunque solo descarga dependencias. Se crean placeholders antes del fetch
# y se sobreescriben con el código real después.
RUN mkdir -p ether-sqlite-core/src ether-sqlite-ffm/src ether-sqlite-jni/src \
 && touch ether-sqlite-core/src/lib.rs ether-sqlite-ffm/src/lib.rs ether-sqlite-jni/src/lib.rs

RUN cargo fetch

# ── Código fuente real ─────────────────────────────────────────────────────
# Se copian los tres crates:
#   ether-sqlite-core: tests TT-1 (--lib) y TT-2 (--test ffi_contract)
#   ether-sqlite-ffm:  cdylib sin tests — se verifica que compila
#   ether-sqlite-jni:  cdylib sin tests — se verifica que compila
COPY sources/rust/ether-sqlite-core/src   ./ether-sqlite-core/src
COPY sources/rust/ether-sqlite-core/tests ./ether-sqlite-core/tests
COPY sources/rust/ether-sqlite-ffm/src    ./ether-sqlite-ffm/src
COPY sources/rust/ether-sqlite-jni/src    ./ether-sqlite-jni/src

# ── Tests y compilación del workspace ─────────────────────────────────────
# TT-1: 137 unit tests internos de ether-sqlite-core
# TT-2: FFI contract tests (tests/ffi_contract.rs)
# TT-3: cargo build -p ether-sqlite-ffm  → verifica que el cdylib FFM compila
# TT-4: cargo build -p ether-sqlite-jni  → verifica que el cdylib JNI compila
CMD ["sh", "-c", \
  "cargo test -p ether-sqlite-core --lib --color always \
   && cargo test -p ether-sqlite-core --test ffi_contract --color always \
   && cargo build -p ether-sqlite-ffm --color always \
   && cargo build -p ether-sqlite-jni --color always \
   && echo '✓ ether-sqlite-ffm y ether-sqlite-jni compilan correctamente'"]
