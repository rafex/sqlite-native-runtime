<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>mx.rafex.ether</groupId>
  <artifactId>ether-sqlite-ffm-java21-runtime</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <name>ether-sqlite-ffm-java21-runtime</name>
  <description>Binding Panama FFM para libether_sqlite_ffm_runtime — Java 21 preview (JEP 442, flag enable-preview). JAR only: bytecode 65.65535 (minor=0xFFFF) no es viable como GraalVM native-image. Para native-image en Java 21 usar ether-sqlite-jni-runtime.</description>

  <properties>
    <!--
      Java 21 LTS + flag enable-preview: Panama FFM preview (JEP 442).
      Bytecode resultante: class file 65, minor version 0xFFFF (65535).
      JAR ONLY — GraalVM native-image no acepta bytecode preview de otra
      version principal. Para native-image en Java 21 usar ether-sqlite-jni-runtime.
    -->
    <java.version>21</java.version>
    <maven.compiler.release>${java.version}</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>

  <dependencies>
    <dependency>
      <groupId>mx.rafex.ether</groupId>
      <artifactId>ether-sqlite-core</artifactId>
      <version>0.1.0</version>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.11.4</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <!-- Java 21 preview: Panama FFM (JEP 442) requiere flag enable-preview -->
          <enablePreview>true</enablePreview>
        </configuration>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.2</version>
        <configuration>
          <!--
            Panama FFM necesita acceso nativo y flag enable-preview en runtime.
            JaCoCo inyecta su agente via @{argLine}.
            Los tests de integracion (@Tag("integration")) se excluyen por defecto.
          -->
          <argLine>@{argLine} --enable-native-access=ALL-UNNAMED --enable-preview</argLine>
          <excludedGroups>integration</excludedGroups>
        </configuration>
      </plugin>

      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>0.8.13</version>
        <executions>
          <execution>
            <id>jacoco-prepare-agent</id>
            <goals><goal>prepare-agent</goal></goals>
          </execution>
          <execution>
            <id>jacoco-report</id>
            <phase>test</phase>
            <goals><goal>report</goal></goals>
          </execution>
          <execution>
            <id>jacoco-check</id>
            <phase>verify</phase>
            <goals><goal>check</goal></goals>
            <configuration>
              <rules>
                <rule>
                  <element>BUNDLE</element>
                  <limits>
                    <limit>
                      <counter>LINE</counter>
                      <value>COVEREDRATIO</value>
                      <minimum>0.99</minimum>
                    </limit>
                  </limits>
                </rule>
              </rules>
              <excludes>
                <exclude>mx/rafex/ether/sqlite/SqliteLibrary.class</exclude>
              </excludes>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <configuration>
          <archive>
            <manifest>
              <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
            </manifest>
          </archive>
        </configuration>
      </plugin>

      <!--
        Fat JAR: shadedArtifactAttached=true conserva el thin JAR e incluye dependencias:
          ether-sqlite-ffm-java21-runtime-{version}.jar      <- thin JAR
          ether-sqlite-ffm-java21-runtime-{version}-fat.jar  <- fat JAR
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <shadedArtifactAttached>true</shadedArtifactAttached>
              <shadedClassifierName>fat</shadedClassifierName>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>

    </plugins>
  </build>

  <profiles>

    <!--
      Perfil integration: activa los tests @Tag("integration").
      Uso: mvn test -Pintegration
    -->
    <profile>
      <id>integration</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-surefire-plugin</artifactId>
            <version>3.5.2</version>
            <configuration combine.self="override">
              <groups>integration</groups>
              <argLine>@{argLine} --enable-native-access=ALL-UNNAMED --enable-preview</argLine>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>

  </profiles>

</project>
