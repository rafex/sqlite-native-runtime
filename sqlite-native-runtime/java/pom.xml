<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>mx.rafex</groupId>
  <artifactId>sqlite-native-runtime</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <name>sqlite-native-runtime</name>
  <description>Binding Panama FFI para libsqlite_native_runtime — compatible con GraalVM 25 Native Image</description>

  <properties>
    <!--
      Java 22 como target de bytecode, compilado con GraalVM JDK 25.
      Panama FFM API (java.lang.foreign.*) se estabilizo en Java 22 (JEP 454).
      Compilar con target 21 es incompatible: en Java 21 la API era PREVIEW y
      enable-preview solo aplica al release actual del compilador, no a releases
      anteriores. Java 22 es el minimo compatible sin flags adicionales.
    -->
    <java.version>22</java.version>
    <maven.compiler.release>${java.version}</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <!-- GraalVM Build Tools - native-maven-plugin -->
    <native.maven.plugin.version>0.10.6</native.maven.plugin.version>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.11.4</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <!-- Sin compilerArgs adicionales: compilamos con GraalVM JDK 25 donde
             Panama FFM es estable. enable-preview solo aplica al release actual
             del JDK y no puede combinarse con un target anterior (release 21). -->
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.2</version>
        <configuration>
          <!--
            Panama FFM necesita acceso nativo. JaCoCo inyecta su agente via @{argLine}
            (late binding): se resuelve en tiempo de ejecucion para incluir el -javaagent
            de JaCoCo. El argLine base añade el flag de Panama.
            Los tests de integracion (@Tag("integration")) se excluyen del run por defecto
            — se activan con: mvn test -Pintegration
          -->
          <argLine>@{argLine} --enable-native-access=ALL-UNNAMED</argLine>
          <excludedGroups>integration</excludedGroups>
        </configuration>
      </plugin>

      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>0.8.12</version>
        <executions>
          <!-- Prepara el agente JaCoCo antes de los tests (inyecta -javaagent en @{argLine}) -->
          <execution>
            <id>jacoco-prepare-agent</id>
            <goals><goal>prepare-agent</goal></goals>
          </execution>
          <!-- Genera el reporte HTML tras los tests -->
          <execution>
            <id>jacoco-report</id>
            <phase>test</phase>
            <goals><goal>report</goal></goals>
          </execution>
          <!-- Verifica la cobertura al hacer mvn verify -->
          <execution>
            <id>jacoco-check</id>
            <phase>verify</phase>
            <goals><goal>check</goal></goals>
            <configuration>
              <rules>
                <rule>
                  <element>BUNDLE</element>
                  <limits>
                    <limit>
                      <counter>LINE</counter>
                      <value>COVEREDRATIO</value>
                      <!--
                        0.99 en lugar de 1.00: existen exactamente 2 lineas de error
                        genuinamente no-testeables sin mocking del runtime nativo:
                          1. SqliteConnection.memory() anonima — el throw cuando
                             sqlite3_open_v2(":memory:") falla (requiere OOM del SO).
                          2. SqliteConnection.savepoint() — el throw cuando
                             sqlite3_exec("SAVEPOINT ...") falla; imposible con el
                             escape de comillas actual y una conexion valida.
                        Todas las demas ramas de error estan cubiertas.
                      -->
                      <minimum>0.99</minimum>
                    </limit>
                  </limits>
                </rule>
              </rules>
              <!--
                SqliteLibrary se excluye porque su bloque static loadLibrary()
                contiene ramas de fallback que requieren manipulacion del filesystem
                o variables de entorno y no son testeables sin un agente de byte-code.
              -->
              <excludes>
                <exclude>mx/rafex/sqlite/SqliteLibrary.class</exclude>
              </excludes>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <configuration>
          <archive>
            <manifest>
              <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
            </manifest>
          </archive>
        </configuration>
      </plugin>

      <!--
        Fat JAR (uber-jar): empaqueta todas las dependencias de runtime en un único JAR
        autónomo. shadedArtifactAttached=true conserva el JAR delgado original intacto
        y adjunta el fat JAR con el clasificador "fat":
          sqlite-native-runtime-{version}.jar      ← thin JAR (para Maven/Gradle)
          sqlite-native-runtime-{version}-fat.jar  ← fat JAR (distribución standalone)
        Actualmente no hay dependencias de runtime, pero la configuración es correcta
        para el futuro y garantiza que el artefacto de release sea explícito.
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <shadedArtifactAttached>true</shadedArtifactAttached>
              <shadedClassifierName>fat</shadedClassifierName>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <!-- Excluir firmas digitales de JARs de terceros para evitar SecurityException -->
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>

    </plugins>
  </build>

  <profiles>
    <!--
      Perfil integration: activa los tests @Tag("integration") que se excluyen por defecto.
      Uso: mvn test -Pintegration
      Estos tests cubren concurrencia, WAL, datasets grandes y recuperación de errores.
    -->
    <profile>
      <id>integration</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-surefire-plugin</artifactId>
            <version>3.5.2</version>
            <configuration combine.self="override">
              <groups>integration</groups>
              <argLine>@{argLine} --enable-native-access=ALL-UNNAMED</argLine>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!--
      Perfil native: compila el smoke test como ejecutable nativo con GraalVM 25.
      Uso: JAVA_HOME=graalvm-25 mvn -Pnative package native:compile
      Binario resultante: target/snr-smoke
    -->
    <profile>
      <id>native</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.graalvm.buildtools</groupId>
            <artifactId>native-maven-plugin</artifactId>
            <version>${native.maven.plugin.version}</version>
            <extensions>true</extensions>
            <configuration>
              <imageName>snr-smoke</imageName>
              <!-- SmokeTest como punto de entrada para verificar la libreria como native image -->
              <mainClass>mx.rafex.sqlite.SmokeTest</mainClass>
              <buildArgs>
                <!-- SqliteLibrary carga la dylib en bloque estatico: inicializar en runtime -->
                <buildArg>--initialize-at-run-time=mx.rafex.sqlite.SqliteLibrary</buildArg>
                <!-- Panama FFM requiere acceso nativo -->
                <buildArg>--enable-native-access=ALL-UNNAMED</buildArg>
                <!-- Incluir test-classes en el classpath del native build -->
                <buildArg>-cp</buildArg>
                <buildArg>${project.build.outputDirectory}:${project.build.testOutputDirectory}</buildArg>
              </buildArgs>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>

</project>
