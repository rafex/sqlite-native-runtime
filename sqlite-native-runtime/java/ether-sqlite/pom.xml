<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>mx.rafex.ether</groupId>
  <artifactId>ether-sqlite-runtime</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <name>ether-sqlite-runtime</name>
  <description>Binding Panama FFI para libether_sqlite_runtime — Java 25 stable (JEP 454)</description>

  <properties>
    <!--
      Java 25 LTS: Panama FFM estable (JEP 454), sin flag enable-preview.
      Para el binding Java 21 preview (JEP 442) ver el módulo ether-sqlite-java21.
    -->
    <java.version>25</java.version>
    <maven.compiler.release>${java.version}</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <!-- GraalVM Build Tools - native-maven-plugin -->
    <native.maven.plugin.version>0.10.6</native.maven.plugin.version>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.11.4</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <!-- Java 25: Panama FFM estable (JEP 454), sin flag enable-preview -->
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.2</version>
        <configuration>
          <!--
            Panama FFM necesita acceso nativo. JaCoCo inyecta su agente via @{argLine}.
            Los tests de integracion (@Tag("integration")) se excluyen por defecto
            — se activan con: mvn test -Pintegration
          -->
          <argLine>@{argLine} --enable-native-access=ALL-UNNAMED</argLine>
          <excludedGroups>integration</excludedGroups>
        </configuration>
      </plugin>

      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>0.8.13</version>
        <executions>
          <execution>
            <id>jacoco-prepare-agent</id>
            <goals><goal>prepare-agent</goal></goals>
          </execution>
          <execution>
            <id>jacoco-report</id>
            <phase>test</phase>
            <goals><goal>report</goal></goals>
          </execution>
          <execution>
            <id>jacoco-check</id>
            <phase>verify</phase>
            <goals><goal>check</goal></goals>
            <configuration>
              <rules>
                <rule>
                  <element>BUNDLE</element>
                  <limits>
                    <limit>
                      <counter>LINE</counter>
                      <value>COVEREDRATIO</value>
                      <!--
                        0.99: existen 2 líneas no-testeables sin mocking del runtime nativo
                        (throw en sqlite3_open_v2 con OOM y throw en savepoint imposible).
                      -->
                      <minimum>0.99</minimum>
                    </limit>
                  </limits>
                </rule>
              </rules>
              <!--
                SqliteLibrary se excluye: su bloque static loadLibrary() tiene ramas
                de fallback no testeables sin manipulación de filesystem o env.
              -->
              <excludes>
                <exclude>mx/rafex/ether/sqlite/SqliteLibrary.class</exclude>
              </excludes>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <configuration>
          <archive>
            <manifest>
              <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
            </manifest>
          </archive>
        </configuration>
      </plugin>

      <!--
        Fat JAR: shadedArtifactAttached=true conserva el thin JAR e incluye dependencias:
          ether-sqlite-runtime-{version}.jar      ← thin JAR
          ether-sqlite-runtime-{version}-fat.jar  ← fat JAR
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <shadedArtifactAttached>true</shadedArtifactAttached>
              <shadedClassifierName>fat</shadedClassifierName>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>

    </plugins>
  </build>

  <profiles>

    <!--
      Perfil integration: activa los tests @Tag("integration").
      Uso: mvn test -Pintegration
    -->
    <profile>
      <id>integration</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-surefire-plugin</artifactId>
            <version>3.5.2</version>
            <configuration combine.self="override">
              <groups>integration</groups>
              <argLine>@{argLine} --enable-native-access=ALL-UNNAMED</argLine>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>

    <!--
      Perfil native: compila SmokeTest como GraalVM Native Image (Java 25 stable).
      Uso: JAVA_HOME=graalvm-25 mvn -Pnative package native:compile
      Binario: target/ether-sqlite
    -->
    <profile>
      <id>native</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.graalvm.buildtools</groupId>
            <artifactId>native-maven-plugin</artifactId>
            <version>${native.maven.plugin.version}</version>
            <extensions>true</extensions>
            <configuration>
              <imageName>ether-sqlite</imageName>
              <mainClass>mx.rafex.ether.sqlite.SmokeTest</mainClass>
              <buildArgs>
                <buildArg>--initialize-at-run-time=mx.rafex.ether.sqlite.SqliteLibrary</buildArg>
                <buildArg>--enable-native-access=ALL-UNNAMED</buildArg>
                <buildArg>-cp</buildArg>
                <buildArg>${project.build.outputDirectory}:${project.build.testOutputDirectory}</buildArg>
              </buildArgs>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>

  </profiles>

</project>
